•	export const rankActivities = (weatherData: any) => {
  // Simple scoring logic:
  return weatherData.time.map((date: string, i: number) => ({
    date,
    scores: [
      { activity: "Skiing", score: weatherData.temperature_2m_max[i] < 0 ? 10 : 3 },
      { activity: "Surfing", score: weatherData.temperature_2m_max[i] > 20 ? 10 : 2 },
      { activity: "Outdoor sightseeing", score: weatherData.precipitation_sum[i] === 0 ? 10 : 4 },
      { activity: "Indoor sightseeing", score: weatherData.precipitation_sum[i] > 0 ? 10 : 5 },
    ],
  }));
};
