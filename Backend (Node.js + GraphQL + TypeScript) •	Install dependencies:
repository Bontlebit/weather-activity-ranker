•	import fetch from 'node-fetch';

export const getWeatherData = async (city: string) => {
  // For simplicity, use Open-Meteo API with city coordinates (example for demo)
  const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=-25.7479&longitude=28.2293&daily=temperature_2m_max,precipitation_sum&timezone=Africa/Johannesburg`);
  const data = await response.json();
  return data.daily;
};
